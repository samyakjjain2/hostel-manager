// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   // "ADMIN" | "WARDEN" | "STUDENT"
  createdAt DateTime @default(now())
}

model Hostel {
  id        String    @id
  name      String
  type      String    // "Boys" | "Girls" | "Co-ed"
  floors    Int
  capacity  Int
  warden    String
  contact   String
  rooms     Room[]
  students  Student[]
}

model Room {
  id         String    @id // e.g. "r-a-101"
  hostelId   String
  hostel     Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  roomNumber String
  floor      Int
  type       String    // "Single" | "Double" | "Triple"
  rent       Int
  status     String    // "Available" | "Maintenance"
  beds       Int
  students   Student[]
}

model Student {
  id                String             @id // e.g. "std-1001"
  name              String
  email             String             @unique
  phone             String
  gender            String             // "Male" | "Female"
  collegeId         String             @unique
  hostelId          String?
  hostel            Hostel?            @relation(fields: [hostelId], references: [id], onDelete: SetNull)
  roomId            String?
  room              Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  bedNo             Int?
  status            String             // "Active" | "Suspended" | "Graduated"
  parentName        String
  parentPhone       String
  feeStatus         String             // "Paid" | "Pending" | "Overdue"
  createdAt         DateTime           @default(now())
  fees              Fee[]
  complaints        Complaint[]
  visitors          Visitor[]
  attendanceRecords AttendanceRecord[]
}

model Fee {
  id        String   @id // e.g. "inv-2001"
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Int
  dueDate   String   // "YYYY-MM-DD"
  paidDate  String?  // "YYYY-MM-DD"
  status    String   // "Paid" | "Pending" | "Overdue"
  term      String   // e.g. "July 2026 Room Rent"
}

model Complaint {
  id          String   @id // e.g. "cmp-3001"
  studentId   String
  studentName String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  category    String   // "Electrical" | "Plumbing" | "Cleaning" | "Internet" | "Others"
  description String   @db.Text
  date        String   // "YYYY-MM-DD"
  status      String   // "Pending" | "In Progress" | "Resolved"
  resolution  String?  @db.Text
}

model Visitor {
  id          String   @id // e.g. "vst-4001"
  name        String
  phone       String
  relation    String
  studentId   String
  studentName String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  checkIn     String   // ISO DateTime
  checkOut    String?  // ISO DateTime
  purpose     String
}

model Staff {
  id     String @id // e.g. "stf-5001"
  name   String
  role   String // "Warden" | "Security Guard" | "Housekeeper" | "Mess Manager" | "Electrician" | "Plumber"
  phone  String
  shift  String // "Day" | "Night" | "Rotational"
  salary Int
  status String // "Active" | "On Leave" | "Inactive"
}

model Attendance {
  id      Int                @id @default(autoincrement())
  date    String             @unique // "YYYY-MM-DD"
  records AttendanceRecord[]
}

model AttendanceRecord {
  id           Int        @id @default(autoincrement())
  attendanceId Int
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String     // "Present" | "Absent" | "Late"
}

model Notice {
  id        String   @id // e.g. "ntc-6001"
  title     String
  content   String   @db.Text
  date      String   // "YYYY-MM-DD"
  category  String   // "Urgent" | "Academic" | "Event" | "Maintenance"
  postedBy  String
}

model Activity {
  id        String   @id // e.g. "act-17833"
  module    String
  action    String
  detail    String
  timestamp String   // ISO DateTime
}
